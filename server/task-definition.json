{
  "family": "signal-relay-server",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "ARM64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::022118847419:role/kyro-dev-ecs-execution",
  "taskRoleArn": "arn:aws:iam::022118847419:role/kyro-dev-ecs-task",
  "containerDefinitions": [
    {
      "name": "relay-server",
      "image": "022118847419.dkr.ecr.us-east-1.amazonaws.com/signal-relay:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "PORT",
          "value": "8080"
        },
        {
          "name": "SIGNAL_ALLOWED_ORIGIN",
          "value": "https://signal.ratimics.com"
        },
        {
          "name": "SIGNAL_REQUIRE_API_TOKEN",
          "value": "1"
        }
      ],
      "secrets": [
        {
          "name": "SIGNAL_API_TOKEN",
          "valueFrom": "arn:aws:secretsmanager:us-east-1:022118847419:secret:signal/api-token-cfXder"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/signal-relay-server",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
